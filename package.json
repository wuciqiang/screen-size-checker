{
  "name": "screen-size-checker",
  "version": "2.3.0",
  "description": "Screen Size Checker - A modern multilingual tool to detect screen resolution, viewport size, and compare device dimensions. Built with component-based architecture.",
  "main": "multilang-build/index.html",
  "scripts": {
    "dev": "python -X utf8 dev-server.py",
    "build": "node build/multilang-builder.js",
    "test-build": "node build/component-builder.js",
    "batch-build": "node scripts/batch-build-all.js",
    "build:content": "node scripts/prepare-generated-components.js",
    "build:page": "node scripts/build-page.js",
    "multilang-build": "node build/multilang-builder.js",
    "validate-components": "node build/component-builder.js",
    "validate:i18n": "node build/translation-validator.js",
    "test": "node scripts/run-test-suite.js",
    "test:smoke": "node scripts/run-test-suite.js --smoke",
    "test:regression": "npm run multilang-build && npm run test:smoke && npm run test:redirects",
    "test:validation": "node test/simple-validation.js",
    "test:links": "node test/internal-links-checker.js",
    "test:seo": "node test/seo-tags-validator.js",
    "test:redirects": "node test/blog-redirect-test.js",
    "ai:refresh-context": "node scripts/refresh-ai-context.js",
    "deploy": "node deploy.js",
    "deploy-check": "node cloudflare-deploy-check.js",
    "performance-check": "node deploy-performance-monitor.js"
  },
  "keywords": [
    "screen-size",
    "viewport",
    "browser-detection",
    "responsive-design",
    "web-development",
    "multilingual",
    "device-comparison",
    "i18n",
    "cloudflare-pages",
    "static-site"
  ],
  "author": "Screen Size Checker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/screen-size-checker"
  },
  "homepage": "https://screensizechecker.com",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "multilang-build/**/*",
    "build/**/*",
    "components/**/*",
    "templates/**/*",
    "locales/**/*",
    "css/**/*",
    "js/**/*"
  ],
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^4.3.0",
    "playwright": "^1.56.0"
  }
}
